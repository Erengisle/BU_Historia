function updateSheet(sheetId, studentName, results, comments, additionalData, colors) {
  if (!sheetId) {
    Logger.log(`Ogiltigt kalkylblads-ID för student: ${studentName}. Kalkylblad uppdateras ej.`);
    return;
  }

  try {
    var spreadsheet = SpreadsheetApp.openById(sheetId);
    var sheet = spreadsheet.getActiveSheet();

    Logger.log(`Skriver data till kalkylblad för ${studentName}: ${sheetId}`);
    
    // Skriv resultat till rad 3 (kolumner B-G)
    results.forEach((result, index) => {
      sheet.getRange(3, index + 2).setValue(result || "-");
    });

    // Skriv kommentarer till rad 4 (kolumner B-G), men bara om data finns
    comments.forEach((comment, index) => {
      if (comment && comment.trim() !== "") {
        sheet.getRange(4, index + 2).setValue(comment);
      }
    });

    // Skriv data från Q2 till I8 och R2 till I9
    var cellI8 = sheet.getRange(8, 9); // I8
    var cellI9 = sheet.getRange(9, 9); // I9
    cellI8.setValue(additionalData[0] || "-"); 
    cellI9.setValue(additionalData[1] || "-"); 

    // Färglägg I8 och I9 baserat på värdet
    var red = colors.red || "#fa0505";
    var green = colors.green || "#22bf4c";
    var noColor = null;

    function setCellColor(cell, value) {
      if (value === "TeB") {
        cell.setBackground(green);
      } else if (value === "IT" || value === "UB") {
        cell.setBackground(red);
      } else {
        cell.setBackground(noColor);
      }
    }

    setCellColor(cellI8, additionalData[0] || "-");
    setCellColor(cellI9, additionalData[1] || "-");

    // Räkna förekomster av E, C eller A i området B3:G3
    var range = sheet.getRange(3, 2, 1, 6);
    var values = range.getValues()[0];
    var count = values.filter(val => ["E", "C", "A"].includes(val)).length;
    sheet.getRange(7, 7).setValue(count); // G7

    // Färglägg G7 och I7
    var cellG7 = sheet.getRange(7, 7);
    var cellI7 = sheet.getRange(7, 9);

    if (count >= 0 && count <= 2) {
      cellG7.setBackground(red);
      cellI7.setBackground(red);
    } else if (count === 3) {
      cellG7.setBackground(colors.yellow || "#f5ed07");
      cellI7.setBackground(colors.yellow || "#f5ed07");
    } else if (count > 3) {
      cellG7.setBackground(green);
      cellI7.setBackground(green);
    }
    
    Logger.log(`Antal E, C eller A i G7 för ${studentName}: ${count}`);
  } catch (error) {
    Logger.log(`Fel vid uppdatering av kalkylblad för ${studentName} (ID: ${sheetId}): ${error.message}`);
  }
}

function createOrUpdateStudentDocuments() {

  // --- NY DEL: Kopiera namn från Grupplista till Samlade resultat ---
  var sourceNamesSheet = SpreadsheetApp.openById("1HkzR5BA3uIcG5ZtGgmOO3NHqq5k7pw8REdCXJg9mGHc")
    .getSheetByName("SPRINT-Hi: Namn och e-postadresser");
  var names = sourceNamesSheet.getRange(2, 1, sourceNamesSheet.getLastRow() - 1, 1).getValues();

  var targetSheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName("Samlade resultat");
  targetSheet.getRange(2, 1, names.length, 1).setValues(names);
  // --- SLUT NY DEL ---

  var sheet = targetSheet;

  if (!sheet) {
    throw new Error("Fliken 'Samlade resultat' hittades inte. Kontrollera fliknamnet i kalkylbladet.");
  }

  var emailSheet = SpreadsheetApp.openById("1HkzR5BA3uIcG5ZtGgmOO3NHqq5k7pw8REdCXJg9mGHc")
    .getSheetByName("SPRINT-Hi: Namn och e-postadresser");
  var emailData = emailSheet.getDataRange().getValues();
  var emailMap = {};
  
  emailData.slice(1).forEach(row => {
    emailMap[row[0]] = row[1];
  });

  var data = sheet.getDataRange().getValues();
  var rows = data.slice(1);

  var templateSheetId = "1ozNLTN_kJPm1_1lV4vwTbiQBFDsIjm5LVaRZGQ0CAuM";
  var folderId = "1KnokYu48l6yHXXi8b5zMgJQTtTPlXxFp";

  var folder = DriveApp.getFolderById(folderId);
  var templateFile = DriveApp.getFileById(templateSheetId);

  rows.forEach(function (row, index) {
    try {
      var studentName = row[0];
      var sheetId = row[15] ? row[15].trim() : "";

      // --- NY LOGGNING ---
      Logger.log(`Rad ${index + 2} - Kolumn A (namn): '${studentName}'`);
      Logger.log(`Rad ${index + 2} - Kolumn P (ID): '${sheetId}'`);
      // --------------------

      if (!studentName) {
        Logger.log(`Tom rad eller saknar studentnamn på rad ${index + 2}. Hoppar över.`);
        return;
      }

      var results = row.slice(1, 7);
      var comments = row.slice(8, 14);
      var additionalData = [row[16], row[17]];

      if (!sheetId || sheetId === "undefined") {
        Logger.log(`Kolumn P är tom eller ogiltig för ${studentName} på rad ${index + 2}. Skapar nytt kalkylblad.`);
        var studentFile = templateFile.makeCopy(`${studentName} - Bedömningar`, folder);
        var newSheetId = studentFile.getId();

        sheet.getRange(index + 2, 16).setValue(newSheetId);
        Logger.log(`Nytt kalkylblads-ID '${newSheetId}' sparat i kolumn P för ${studentName}.`);

        updateSheet(newSheetId, studentName, results, comments, additionalData, {
          red: "#FF0000",
          yellow: "#FFFF00",
          green: "#00FF00"
        });

        var email = emailMap[studentName];
        if (email) {
          studentFile.addEditor(email);
          GmailApp.sendEmail(email, `Dokument för ${studentName}`, `Hej ${studentName},\n\nDitt dokument är klart. Du hittar det här: ${studentFile.getUrl()}\n\nVänliga hälsningar,\nAdministrationen`);
        } else {
          Logger.log(`E-postadress saknas för ${studentName}.`);
        }
      } else {
        Logger.log(`Kontrollerar kalkylblads-ID för ${studentName}: ${sheetId}`);
        updateSheet(sheetId, studentName, results, comments, additionalData, {
          red: "#FF0000",
          yellow: "#FFFF00",
          green: "#00FF00"
        });
      }
    } catch (error) {
      Logger.log(`Fel på rad ${index + 2} för student '${row[0] || "Okänd"}': ${error.message}`);
    }
  });
}
